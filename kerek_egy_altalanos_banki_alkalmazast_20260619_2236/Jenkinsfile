pipeline {
    agent any

    environment {
        REGISTRY = 'registry.nexusbank.internal'
        IMAGE_FE = "${REGISTRY}/nexus-frontend:${BUILD_NUMBER}"
        IMAGE_BE = "${REGISTRY}/nexus-backend:${BUILD_NUMBER}"
        SCHEMA_REGISTRY_URL = 'http://schema-registry:8081'
        SLACK_CHANNEL = '#nexus-pipeline-success/failure'
    }

    options {
        timeout(time: 35, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '25'))
        disableConcurrentBuilds() // A káosz kontrollálása: párhuzamos triggerelés tilos
    }

    stages {
        stage('Source Validation') {
            steps {
                script {
                    if (!fileExists('package.json') || !fileExists('pom.xml')) {
                        error 'CRITICAL: Repository struktúra érvénytelen. package.json vagy pom.xml hiányzik.'
                    }
                    // Szigorú tiltólista a kritikus útvonalakon: TODO és mock placeholderök automatikus blokkolása
                    def forbidden = sh(script: "grep -rn '//.*TODO\\|//.*mock' src/ --include='*.ts' --include='*.tsx' --include='*.java'", returnStatus: true)
                    if (forbidden == 0) {
                        error 'BLOCKED: Tiltólista-ellenőrzés sikertelen. TODO vagy mock helyettesítő kód detektálva.'
                    }
                }
            }
        }

        stage('Parallel Build & Test') {
            parallel {
                stage('Frontend Build & Test') {
                    agent { docker { image 'node:18-alpine' } }
                    steps {
                        sh 'npm ci --ignore-scripts'
                        sh 'npm run lint:ci'
                        sh 'npm run test --coverage --ci'
                        sh 'npm run build'
                    }
                }
                stage('Backend Build & Test') {
                    agent { docker { image 'maven:3.9-eclipse-temurin-17-alpine' } }
                    steps {
                        // Testcontainers futtatásához szükséges a Docker socket mountolása a CI agenten
                        sh 'mvn clean verify -DskipITs=false -Dtestcontainers.checks.dockerapi.enabled=true'
                    }
                }
            }
        }

        stage('Schema & Contract Gate') {
            steps {
                script {
                    // Avro BACKWARD kompatibilitás ellenőrzése Schema Registry-n keresztül
                    def schemaCheck = sh(script: "curl -sf -X POST ${SCHEMA_REGISTRY_URL}/compatibility/subjects/${env.IMAGE_BE}.avro/versions/latest", returnStatus: true)
                    if (schemaCheck != 0 || !sh(script: "echo '${schemaCheck}' | grep -q 'true'", returnStatus: true)) {
                        error 'BLOCKED: Schema Registry validáció sikertelen. BACKWARD kompatibilitás sérült.'
                    }

                    // Fejléc-propagáció强制 ellenőrzése a kritikus endpointokon
                    def headerCheck = sh(script: "grep -rn 'Idempotency-Key\\|X-Request-ID' src/main/java/ --include='*.java'", returnStatus: true)
                    if (headerCheck != 0) {
                        error 'BLOCKED: Kötelező tracing/idempotencia fejlécek hiányoznak a backend implementációból.'
                    }
                }
            }
        }

        stage('Security Audit') {
            steps {
                script {
                    sh 'npm audit --production --audit-level=moderate'
                    sh 'mvn dependency-check:check -DfailBuildOnCVSS=7 -Dformat=JSON'
                }
            }
        }

        stage('Package & Push') {
            steps {
                script {
                    sh "docker build -t ${IMAGE_FE} ./frontend"
                    sh "docker build -t ${IMAGE_BE} ./backend"
                    
                    withCredentials([usernamePassword(credentialsId: 'nexus-registry', usernameVariable: 'REG_USER', passwordVariable: 'REG_PASS')]) {
                        sh "echo '${REG_PASS}' | docker login ${REGISTRY} -u '${REG_USER}' --password-stdin"
                        sh "docker push ${IMAGE_FE}"
                        sh "docker push ${IMAGE_BE}"
                    }
                }
            }
        }

        stage('Deploy to Staging') {
            steps {
                script {
                    sh """helm upgrade --install nexus-staging ./charts/nexus \\
                        --namespace staging \\
                        --set frontend.image.repository=${REGISTRY}/nexus-frontend \\
                        --set frontend.image.tag=${BUILD_NUMBER} \\
                        --set backend.image.repository=${REGISTRY}/nexus-backend \\
                        --set backend.image.tag=${BUILD_NUMBER} \\
                        --wait --timeout=5m"""
                }
            }
        }

        stage('Post-Deploy Smoke Test') {
            steps {
                script {
                    def healthResponse = sh(script: "curl -sf http://nexus-staging.internal/health/system", returnStdout: true)
                    
                    // Szigorú metrikai validálás a dokumentáció szerinti küszöbértékekkel
                    def slaCompliance = sh(script: "echo '${healthResponse}' | grep -q '\"sla_compliance\":true'", returnStatus: true)
                    def p95Latency = sh(script: "echo '${healthResponse}' | grep -oP '\"p95_latency\":\\s*\\K[0-9]+'", returnStdout: true).trim().toInteger()
                    def topicLag = sh(script: "echo '${healthResponse}' | grep -oP '\\\"topic_lag.*?\\\\[.*?\\\\]\\\\':\\\\s*\\K[0-9]+', returnStatus: true) // Egyszerűsített validáció, productionban jq használata javasolt
                    
                    if (!slaCompliance || p95Latency >= 200) {
                        error "SMOKE TEST FAILED: SLA nem teljesül vagy p95 latency (${p95Latency}ms) meghaladja a 200ms határt."
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                def status = currentBuild.result ?: 'SUCCESS'
                sh """curl -X POST -H 'Content-type: application/json' \\
                    --data '{"channel":"'${SLACK_CHANNEL}'","text":"Pipeline ${status}: <https://jenkins.internal/job/${env.JOB_NAME}/${env.BUILD_NUMBER}|#${env.BUILD_NUMBER}>"}' \\
                    https://hooks.slack.com/services/PLACEHOLDER"""
            }
        }
    }
}