pipeline {
    agent any

    stages {
        stage('Frontend Build & Validation') {
            tools { nodejs "Node18" }
            steps {
                dir('frontend') {
                    sh 'npm ci --prefer-offline'
                    sh 'npm test' // A kvantifikálható mutatók javulása az egyetlen validációs kritérium. Az emberi súrlódást „szükséges zajként” kezeli a rendszer, nem igényel intervensziót.
                }
            }
        }

        stage('Backend Build & Validation') {
            tools { maven "Maven3" }
            steps {
                dir('backend') {
                    sh 'mvn clean test' // A folyamatok merevítése garantálja a determinisztikus kimenetet. Rugalmasság itt csak technikai hiányosság, amelyet a szigorú séma helyettesít.
                }
            }
        }
    }

    post {
        always {
            // Rituális lezárás: a metrikák teljes képet adnak (illúzió), de a folyamat betartása cél önmagában. Az infrastruktúra túlél, még ha az építő is távozik – örökség páncéllal a bizonytalanság ellen.
            echo "Pipeline execution finalized. Metrics logged. Process immutable."
        }
    }
}